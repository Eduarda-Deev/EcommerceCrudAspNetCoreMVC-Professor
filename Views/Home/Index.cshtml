@{
    ViewData["Title"] = "Home Page";
}

<section class="hero">

    <img src="https://i.pinimg.com/originals/73/36/d7/7336d75e527acb303e9a14fa2ce20e81.gif"
           alt="Gif animado" class="hero-video">


    <div class="hero-content">

        <h1 class="hero-title">
            Bem-vindo à <span class="brand">Hace al Monje</span>
        </h1>

        <p class="hero-subtitle">
            “Hace el Monje” é o espaço onde arte encontra propósito.
        </p>

        <p class="hero-ai-text">
            <span id="Type"></span>
        </p>

        <div class="hero-buttons">
            <a href="/Usuario/Login" class="btn btn-outline-light btn-lg">Login</a>
            <a href="/Usuario/Cadastrar" class="btn btn-outline-light btn-lg">Cadastrar</a>
        </div>

    </div>

</section>

<div id="myPlot" style="width:100%;max-width:900px"></div>

<script>const xArray = ["Itália", "Brasil", "Espanha", "França", "Argentina"];
    const yArray = [55, 49, 44, 24, 15];

    const data = [{
        labels: xArray,
        values: yArray,
        type: "pie",
        hole: .35,
        textinfo: "label+percent",
        hoverinfo: "label+percent+value",
        marker: {
            colors: [
                "#193060",
                "#859FC0",
                "#193060",
                "#CEE0F4",
                "#315381"
            ]
        }
    }];

    const layout = {
        title: {
            text: "Vendas globais de Hace al Monje",
            font: {
                size: 24,
                color: "#ffffff"
            }
        },

        paper_bgcolor: "rgba(0,0,0,0)",
        plot_bgcolor: "rgba(0,0,0,0)",

        font: {
            color: "#ffffff"
        },

        showlegend: true
    };

    const config = {
        responsive: true,
        displayModeBar: true
    };

    Plotly.newPlot("myPlot", data, layout, config);</script>

<div id="carouselExample" class="carousel slide" data-bs-ride="carousel">

    <div class="carousel-inner">

        <div class="carousel-item active">
            <img src="https://i.pinimg.com/1200x/5b/33/6a/5b336a6b2df66ca1cf6f9400f8b5c2d2.jpg" class="d-block w-100">

            <div class="carousel-caption">
                <h2>Artistas de todo o mundo</h2>
                <p>A arte transforma o futuro</p>
            </div>
        </div>

        <div class="carousel-item">
            <img src="https://i.pinimg.com/1200x/bc/da/c5/bcdac5e5b34dc3635bd7d5356e65951c.jpg" class="d-block w-100">

            <div class="carousel-caption">
                <h2>Comissões variadas</h2>
                <p>Movimentos artísticos independentes</p>
            </div>
        </div>

        <div class="carousel-item">
            <img src="https://i.pinimg.com/736x/f2/f3/b1/f2f3b10f1e24055248b08f96e242a1a2.jpg" class="d-block w-100">

            <div class="carousel-caption">
                <h2>Hace al Monje</h2>
                <p>Construindo o futuro da arte</p>
            </div>
        </div>

    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>