@{
    ViewData["Title"] = "Sobre";
}

<div class="about-container">

    <div class="about-card">

        <h1 class="about-title">Sobre a RoboForge</h1>

        <p class="about-text">
            A <span class="brand">RoboForge</span> nasceu com a missão de transformar o futuro através da robótica e da automação inteligente.
        </p>

        <p class="about-text">
            Desenvolvemos robôs de última geração para impulsionar empresas, facilitar tarefas humanas e criar um novo padrão tecnológico.
        </p>

        <p class="about-text">
            Nosso compromisso é com a inovação, segurança e evolução contínua da tecnologia.
        </p>

        <div class="about-stats">

            <div class="stat-box">
                <h2>+500</h2>
                <p>Robôs vendidos</p>
            </div>

            <div class="stat-box">
                <h2>+120</h2>
                <p>Clientes ativos</p>
            </div>

            <div class="stat-box">
                <h2>99%</h2>
                <p>Satisfação</p>
            </div>

        </div>

    </div>

</div>